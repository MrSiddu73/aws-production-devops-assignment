{
  "agent": {
    "metrics_collection_interval": 60,
    "run_as_user": "root"
  },
  "metrics": {
    "namespace": "DevOpsAssignment",
    "append_dimensions": {
      "InstanceId": "${aws:InstanceId}"
    },
    "metrics_collected": {
      "cpu": {},
      "mem": {},
      "disk": {}
    }
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/home/ubuntu/aws-production-devops-assignment/app/logs/access.log",
            "log_group_name": "DevOpsAssignment-App"
          },
          {
            "file_path": "/var/log/nginx/access.log",
            "log_group_name": "DevOpsAssignment-Nginx-Access"
          }
        ]
      }
    }
  }
}